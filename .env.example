# Copy to `.env` for local development (never commit `.env`).
# Production: set these in your host dashboard (e.g. Render), not in the repo.

# Required. Use a strong password and restrict network access to the database.
DATABASE_URL=postgresql://user:password@localhost:5432/notes_dev

# Optional. Defaults to 3000 locally; Render sets PORT automatically.
# PORT=3000

# Optional. Set to `true` on Render so rate limits use the real client IP from X-Forwarded-For.
# TRUST_FORWARDED_FOR=true

# Optional. `production` enables Secure cookies and HSTS (see src/http/headers.ts).
# NODE_ENV=development
